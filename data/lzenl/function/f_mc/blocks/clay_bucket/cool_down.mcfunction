execute unless score @s active matches 1..100 run return fail


scoreboard players remove @s active 1




execute unless score @s active matches 0 run return fail

execute if score @s .id matches 0 run item replace entity @s contents with player_head[profile={properties:[{name:"textures",value:""}]}] 1

execute if score @s .id matches 1 run item replace entity @s contents with player_head[profile={properties:[{name:"textures",value:""}]}] 1

execute if score @s .id matches 2 run item replace entity @s contents with player_head[profile={properties:[{name:"textures",value:""}]}] 1
