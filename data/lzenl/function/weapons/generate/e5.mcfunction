#Forward skill
$execute if score #ghw.type2 .data matches 2 run data modify storage temp data.weapon.lore set value '[{text:"$(special)reates ",color:dark_gray,italic:false},{text:"$(count) attack/s",color:"#787878",italic:false}],{text:"that move forward from the player.",color:dark_gray,italic:false},[{text:"Each attack moves every ",color:dark_gray,italic:false},{text:"$(speed)s",color:"#787878",italic:false},{text:", travels up to",color:dark_gray,italic:false}],[{text:"$(range)m",color:"#787878",italic:false},{text:", and deals",color:dark_gray,italic:false},{text:" $(dmg)$(type)",color:"$(color)",italic:false},{text:" damage.",color:"$(color)",italic:false}]'

#Chain skill
$execute if score #ghw.type2 .data matches 3 run data modify storage temp data.weapon.lore set value '{text:"$(special)reates a$(type) attack",color:dark_gray,italic:false},[{text:"that moves forward every ",color:dark_gray,italic:false},{text:"$(speed)s",color:"#787878",italic:false}],[{text:"and travels up to ",color:dark_gray,italic:false},{text:"$(range)m.",color:"#787878",italic:false},{text:" When it hits an enemy,",color:dark_gray,italic:false}],{text:"it redirects to the nearest enemy",color:dark_gray,italic:false},{text:"and resets its travel range.",color:dark_gray,italic:false},[{text:"This can occur up to ",color:dark_gray,italic:false},{text:"$(count) times",color:"#787878",italic:false},{text:".",color:dark_gray,italic:false}],[{text:"Each hit deals",color:dark_gray,italic:false},{text:" $(dmg)$(type)",color:"$(color)",italic:false},{text:" damage.",color:"$(color)",italic:false}]'

