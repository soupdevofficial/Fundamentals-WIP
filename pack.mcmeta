{
	"pack": {
		
		"pack_format": 89,

			"min_format": 89,
			"max_format": 100,

		"description": "rehaul minecraft completely"
	},
	"filter": {
		"block": [
		  {
			"namespace": "^minecraft$",
			"path": "^recipe/ender_eye\\.json$"
		  },
		  {
